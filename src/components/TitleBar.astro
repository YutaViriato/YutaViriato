---
---

<header class="titlebar">
  <div class="titlebar__left">
    <div class="titlebar__controls" aria-hidden="true">
      <span class="tdot tdot--close"></span>
      <span class="tdot tdot--min"></span>
      <span class="tdot tdot--max"></span>
    </div>
    <a class="brand" href="/" aria-label="viriato.site — início">
      <span class="brand__sym">&gt;_</span>
      <span class="brand__name">viriato<span class="brand__dot">.site</span></span>
    </a>
  </div>
  <p class="crumb" aria-hidden="true">
    <span class="crumb__file" id="crumb-file">about.ts</span>
  </p>
  <div class="titlebar__spacer" aria-hidden="true"></div>
</header>

<style>
  .titlebar {
    height: var(--titlebar-h);
    flex: none;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    column-gap: 1.25rem;
    padding-inline: 0.9rem;
    background: var(--ink-800);
    border-bottom: 1px solid var(--line);
  }
  .titlebar__left { display: flex; align-items: center; gap: 0.9rem; justify-self: start; }
  .titlebar__controls { display: flex; gap: 0.5rem; }
  .titlebar__spacer { justify-self: end; }
  .tdot { width: 12px; height: 12px; border-radius: 50%; background: var(--ink-600); }
  .tdot--close { background: #ff6f6f; }
  .tdot--min { background: #ffcb6b; }
  .tdot--max { background: var(--mint); }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--step--1);
    letter-spacing: -0.01em;
  }
  .brand__sym { color: var(--mint); }
  .brand__dot { color: var(--text-faint); }

  .crumb {
    justify-self: center;
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-faint);
  }
  .crumb__file { color: var(--text-dim); }

  @media (max-width: 540px) {
    .brand__name { display: none; }
  }
</style>
